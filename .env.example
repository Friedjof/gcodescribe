OCTOPRINT_URL=http://octopi.local
OCTOPRINT_API_KEY=your-octoprint-api-key
OCTOPRINT_VERIFY_SSL=true
PRINTER_SERIAL_ENABLED=false
PRINTER_DEFAULT_BACKEND=
PRINTER_SERIAL_PORT=/dev/ttyUSB0
PRINTER_SERIAL_BAUD=115200
PLOTTER_HOST_PORT=8000
PLOTTER_DATA_DIR=data
PLOTTER_HOST=0.0.0.0
PLOTTER_PORT=8000
REDIS_URL=redis://localhost:6379/0
PLOTTER_AUTH_SESSION_TTL=1209600
PLOTTER_AUTH_COOKIE_SECURE=false
# Image tag used by compose.prod.yml (GHCR). Pin e.g. v0.2.0 for reproducible deploys.
GCODESCRIBE_TAG=latest
